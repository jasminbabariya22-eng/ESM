2026-03-19 12:13:39 | INFO | RESPONSE | GET http://127.0.0.1:8000/risk/risks_by_id/63 | STATUS: 200 | TIME: 0.0299s | BODY: {"data":[{"risk_register_id":63,"risk_id":"IOOT-0001","risk_name":"IT/OT Risk","dept_id":15,"risk_owner_id":2,"financial_year":"2025-2026","risk_status":1,"risk_progress":87.0,"risk_function_head_approval_status":null,"risk_function_head_approval_remark":null,"risk_function_head_approval_on":null,"risk_function_head_approval_by":null,"risk_head_approval_status":null,"risk_head_approved_on":null,"risk_head_approval_remark":null,"risk_head_approval_by":null,"risk_manager_approval_status":null,"risk_manager_approved_on":null,"risk_manager_approval_remark":null,"risk_manager_approval_by":null,"created_by":1,"created_on":"2026-03-13T11:37:32.096575","modified_by":null,"modified_on":null,"is_active":0,"is_deleted":0,"risk_co_owner_id":2,"risk_owner_name":null,"risk_co_owner_name":null,"risk_status_name":"New","risk_descriptions":[{"risk_description_id":44,"risk_register_id":63,"risk_id":"IOOT-0001","risk_description":"Cyber Attack\n1. Malwar, ransomware and phishing etc.\n2. Lack of a patching and week access control.\n3. Unsecured network configuration.\n4.  IT /OT convergence attack via OT.\n5. Website attacks.\n6. Misconfiguration of the system.","inherent_risk_likelihood_id":3,"inherent_risk_impact_id":4,"mitigation":"1. The IT environment is secured with cybersecurity controls such as DDOS protection, SIEM, perimeter, web, application, and endpoint security. Moreover, MFA and access control are implemented to enhance user verification and protect sensitive data.\n2. Quarterly Scanning for Vulnerability and remediation of the same using patch management for CS-DC and PIL-DC.\n3. Web Application Firewall (WAF) is implemented to protect web applications from attacks, but it needs to be properly tuned for effective functioning.\n4. Yearly VAPT is conducted and appropriate observations are remediated.\n5. Availability of Cyber related insurance Policy.\n6. Annual fire drills/DR Drill to enhance incident preparedness for cyber attacks and execution of incident response plan during cybersecurity exercises.\n7.  Arrangements to obtain specialist advice\nand services post-breach.\n8. Business continuity plans include\ncyber risk scenarios.\n","current_risk_likelihood_id":3,"current_risk_impact_id":3,"created_by":1,"created_on":"2026-03-13T11:43:40.308032","modified_by":null,"modified_on":null,"is_deleted":0,"inherent_color_str":"#FF9800","inherent_color_code":"3D","current_color_str":"#FFEB3B","current_color_code":"3C","treatments":[{"risk_treatment_id":46,"risk_description_id":44,"risk_register_id":63,"risk_id":"IOOT-0001","action_plan":"Quarterly Scanning for Vulnerability and remediation of the same using patch management for CS-DC and PIL-DC.","action_owner_id":4,"target_date":"2025-12-31T00:00:00","progress":0.0,"action_status_id":1,"next_followup_date":null,"created_on":"2026-03-13T11:48:25.686395","created_by":1,"modified_on":null,"modified_by":null,"is_deleted":0,"action_owner_name":"raja","treatment_status_name":"New"},{"risk_treatment_id":47,"risk_description_id":44,"risk_register_id":63,"risk_id":"IOOT-0001","action_plan":"Enable WAF and IDS/IPS on Controls-DC for enhanced security.","action_owner_id":3,"target_date":"2025-12-31T00:00:00","progress":0.0,"action_status_id":1,"next_followup_date":null,"created_on":"2026-03-13T11:49:36.473862","created_by":1,"modified_on":null,"modified_by":null,"is_deleted":0,"action_owner_name":null,"treatment_status_name":"New"}]}]}],"Error":{"Error":false,"Error_message":"Success","Error_Code":200}}
